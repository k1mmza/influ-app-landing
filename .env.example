# Both are NEXT_PUBLIC_ and are BAKED INTO THE BUNDLE AT BUILD TIME.
# There is no server at runtime to read them fresh — set them for the build.

# Production backend the browser fetches the live roster from (client-side).
# The build FAILS if this is unset or points at localhost (scripts/check-env.mjs).
NEXT_PUBLIC_API_URL=https://influ-app-backend.onrender.com

# The main app (Vercel/SSR). Every in-content link to an app route
# (/discover, /register, /login, /agencies, /creators, ...) is rewritten to
# an absolute URL under this origin, because those routes do NOT exist on the
# static landing site.
NEXT_PUBLIC_APP_URL=https://app.inflique.com
